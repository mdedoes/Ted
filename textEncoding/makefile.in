CC=@CC@
ICONV_CFLAGS=@ICONV_CFLAGS@

INCLUDES=			\
	$(ICONV_CFLAGS)		\
	-I../include		\
	-I../appUtil		\
	-I.

CFLAGS=	@CFLAGS@ 	\
	$(INCLUDES)

WFLAGS=	-Wall			\
	-Wextra			\
	-Winit-self		\
	-pedantic		\
	-Wpointer-arith		\
	-Wno-format-y2k		\
	-Wstrict-prototypes	\
	-Wmissing-declarations	\
	-Wmissing-prototypes	\
	-Wnested-externs	\
	-Wuninitialized		\
	-Wundef			\
	-Wwrite-strings		\
	-Wold-style-definition	\
	-Wno-missing-field-initializers	\
	-Wredundant-decls	\
	-Wno-unused-parameter	\
	-Wno-sign-compare

#CFLAGS	= $(WFLAGS) -g -O2 $(INCLUDES)

# 69!!obs
OBS	=	\
		utilOfficeCharset.o\
		utilHtmlCharEntities.o\
