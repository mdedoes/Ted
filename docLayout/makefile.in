		docPsPrintTabs.o\
		docPsPrintStructure.o\
		docPsPrintShapes.o\
		docPsPrintPdfmarks.o\
		docPsPrintOrnaments.o\
		docPsPrintLineStructure.o\
		docPsPrintImage.o\
