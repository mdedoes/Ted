		docDescribeSetSelection.o\
		docAdjustParentLayout.o\
		docAdjustParaLayout.o

../lib/docLayout.a:	$(OBS)
	ar ruv $@ $(OBS) && @RANLIB@ $@

#
#  This is cyclic, but at least it documents what extra autoconf configuration
#  is used in this directory:
#
ACLOCAL=

# aclocal.m4:	$(ACLOCAL)
# 	cat $(ACLOCAL) > $@

configure: configure.in
	rm -rf config.cache autom4te.cache
	autoconf

duplicates:
	nm *.o | grep -w [Tt] | \
	while read addr t name; do echo $$name; done | sort | uniq -c | sort -n

includes:
	includes.sh docLayoutConfig.h $(INCLUDES)

