CC=@CC@

WFLAGS=	-Wall			\
	-Wextra			\
	-Winit-self		\
	-pedantic		\
	-Wpointer-arith		\
	-Wno-format-y2k		\
	-Wstrict-prototypes	\
	-Wmissing-declarations	\
	-Wmissing-prototypes	\
	-Wnested-externs	\
	-Wuninitialized		\
	-Wundef			\
	-Wshadow		\
	-Wlogical-op		\
	-Wnull-dereference	\
	-Wwrite-strings		\
	-Wold-style-definition	\
	-Wno-missing-field-initializers	\
	-Wredundant-decls	\
	-Wno-unused-parameter	\
	-Wno-sign-compare	\
	-fsanitize=address	\
	-Werror

INCLUDES=			\
	-I../guiInterface	\
	-I../docEdit		\
	-I../docBuf		\
	-I../docField		\
	-I../docBase		\
	-I../drawMeta		\
	-I../bitmap		\
	-I../utilPs		\
	-I../docFont		\
	-I../textEncoding	\
	-I../utilGeo		\
	-I../appUtil		\
	-I../include

CFLAGS=	\
	@CFLAGS@		\
	$(INCLUDES)

#CFLAGS= -g -O2 $(WFLAGS) $(INCLUDES)

# 77!!obs
OBS	=	\
		layoutContext.o\
		docValignCells.o\
		docStripLayoutJob.o\
		docSelectLayout.o\
		docSelectionGeometry.o\
