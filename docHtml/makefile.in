CC=@CC@

WFLAGS=	-Wall			\
	-Wextra			\
	-Winit-self		\
	-pedantic		\
	-Wpointer-arith		\
	-Wno-format-y2k		\
	-Wstrict-prototypes	\
	-Wmissing-declarations	\
	-Wmissing-prototypes	\
	-Wnested-externs	\
	-Wuninitialized		\
	-Wundef			\
	-Wwrite-strings		\
	-Wold-style-definition	\
	-Wno-missing-field-initializers	\
	-Wredundant-decls	\
	-Wno-unused-parameter	\
	-fsanitize=address	\
	-Wno-sign-compare	\
	-Werror

INCLUDES=			\
	-I../guiInterface	\
	-I../docEdit		\
	-I../docLayout		\
	-I../docBuf		\
	-I../docBase		\
	-I../drawMeta		\
	-I../bitmap		\
	-I../utilPs		\
	-I../docFont		\
	-I../textEncoding	\
	-I../utilGeo		\
	-I../appUtil		\
	-I../include

CFLAGS=	\
	@CFLAGS@		\
	$(INCLUDES)

#CFLAGS= -g -O2 $(WFLAGS) $(INCLUDES)

# 19!!obs
OBS	=	\
		docWriteCss.o\
		docSvgDrawTextLine.o\
		docSvgDrawShapeText.o\
		docSvgDrawShapes.o\
		docSvgDrawImage.o\
		docSvgDraw.o\
		docMarkdownWrite.o\
		docHtmlWriteParagraph.o\
		docHtmlWriteNotes.o\
		docHtmlWriteNode.o\
		docHtmlWriteImage.o\
		docHtmlWriteHtml.o\
		docHtmlWriteField.o\
		docHtmlWriteEpub.o\
		docHtmlWriteEml.o\
		docHtmlWriteCss.o\
		docHtmlWrite.o

../lib/docHtml.a:	$(OBS)
	ar ruv $@ $(OBS) && @RANLIB@ $@

#
#  This is cyclic, but at least it documents what extra autoconf configuration
#  is used in this directory:
#
ACLOCAL=

#aclocal.m4:	$(ACLOCAL)
#	cat $(ACLOCAL) > $@

configure: configure.in
	rm -rf config.cache autom4te.cache
	autoconf

duplicates:
	nm *.o | grep -w [Tt] | \
	while read addr t name; do echo $$name; done | sort | uniq -c | sort -n

includes:
	includes.sh docHtmlConfig.h $(INCLUDES)

# deps -I. -I../include -I ../guiInterface -I../docBuf -I../docLayout -I../docEdit -I../docBase -I../bitmap  -I../drawMeta  -I../textEncoding -I../utilGeo -I../appUtil -I ../docFont -I../utilPs
######################################## !! sh

