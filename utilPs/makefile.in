CC=@CC@

INCLUDES=			\
	-I../textEncoding	\
	-I../appUtil		\
	-I../include

CFLAGS=	@CFLAGS@ 	\
	$(INCLUDES)

WFLAGS=	-Wall			\
	-Wextra			\
	-Winit-self		\
	-pedantic		\
	-Wpointer-arith		\
	-Wno-format-y2k		\
	-Wstrict-prototypes	\
	-Wmissing-declarations	\
	-Wmissing-prototypes	\
	-Wnested-externs	\
	-Wuninitialized		\
	-Wundef			\
	-Wwrite-strings		\
	-Wold-style-definition	\
	-Wno-missing-field-initializers	\
	-Wredundant-decls	\
	-Wno-unused-parameter	\
	-fsanitize=address	\
	-Wno-sign-compare	\
	-Werror

#CFLAGS= $(WFLAGS) -g -O2 $(INCLUDES)

# 36!!obs
OBS	=	\
		textAttributeUtil.o\
		textAttribute.o\
		textAttributeAdmin.o\
		svgWriter.o\
		psTtfTableEntry.o\
		psTtfNameTable.o\
		psTtfFontInfo.o\
		psTtf.o\
		psTextExtents.o\
		psT42.o\
		psShading.o\
		psReadAfm.o\
		psPrintShape.o\
		psPrintProcs.o\
		psPrintPdf.o\
		psPrint.o\
		psPostScriptFontList.o\
		psPdfmark.o\
		psNup.o\
		psMatchFont.o\
		psIncludeEps.o\
		psGlyphs.o\
		psFontName.o\
		psFontMetrics.o\
		psFontInfo.o\
		psFontFamily.o\
		psFontCatalog.o\
		psFace.o\
		psDsc.o\
		psDocumentFonts.o\
		psCompareFontInfo.o\
		psBuildConfig.o\
		psBase35.o\
		psAfm.o


../lib/utilPs.a:	$(OBS)
	ar ruv $@ $(OBS) && @RANLIB@ $@

configure: configure.in
	rm -rf config.cache autom4te.cache
	autoconf

#
#  Check for duplicate symbols
#
duplicates:
	nm *.o | grep -w [Tt] | \
	while read addr t name; do echo $$name; done | sort | uniq -c | sort -n

includes:
	includes.sh utilPsConfig.h $(INCLUDES)

# deps -I../include -I../appUtil -I../textEncoding -I.
