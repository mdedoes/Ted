########################################################################
#
#		Platform for distribution
SYSTEM=		@M_SYSTEM@
MACHINE=	@M_MACHINE@
ARCH=		@M_ARCH@
PLATFORM=	@M_PLATFORM@
#
#		Location for distribution
I_PREFIX=	@PREFIX@

#
#		Name of the binary arrchive
VERSION=	2.22
BINDIST=	ted-2.22-$(PLATFORM)
#
#
PKG_OWNER=	@M_PKG_OWNER@
PKG_GROUP=	@M_PKG_GROUP@
CHOWN_ARG=	@M_CHOWN_ARG@
CHOWN_CMD=	@CHOWN_CMD@
CHECK_ID_CMD=	@CHECK_ID_CMD@
#
#
########################################################################

package:	../Ted/Ted.static	\
		TedBindist.tar		\
		$(BINDIST).lsm		\
		installTed.sh		\
		README
	:
	@CHECK_ID_CMD@
	:
	rm -rf scratch
	:
	mkdir scratch
	mkdir scratch/bin
	mkdir scratch/Ted
	mkdir scratch/Ted/varia
	:
	$(CHOWN_CMD) scratch
	$(CHOWN_CMD) scratch/bin
	$(CHOWN_CMD) scratch/Ted
	$(CHOWN_CMD) scratch/Ted/varia
	:
	chmod 755 scratch
	chmod 755 scratch/bin
	chmod 755 scratch/Ted
	chmod 755 scratch/Ted/varia
	:
	( cd scratch && umask 0 && tar xvf ../TedBindist.tar )
	cp scratch/Ted/TedDocument-en_US.rtf TedDocument-en_US.rtf
	:
	cp ../Ted/Ted.static scratch/bin/Ted
	strip scratch/bin/Ted
	$(CHOWN_CMD) scratch/bin/Ted
	chmod 755 scratch/bin/Ted
	:
	cp $(BINDIST).lsm scratch/Ted/varia/Ted-$(VERSION).lsm
	$(CHOWN_CMD) scratch/Ted/varia/Ted-$(VERSION).lsm
	chmod 644 scratch/Ted/varia/Ted-$(VERSION).lsm
	:
	( cd scratch && tar cvf - @TAR_CHOWN_ARGS@ * | gzip -9 > ../$(BINDIST).tar.gz )
	:
	$(CHOWN_CMD) README
	$(CHOWN_CMD) TedDocument-en_US.rtf
	$(CHOWN_CMD) $(BINDIST).tar.gz
	$(CHOWN_CMD) installTed.sh
	:
	test x_$$RPM_BUILD_ROOT != x_ || chmod 644 README
	test x_$$RPM_BUILD_ROOT != x_ || chmod 644 TedDocument-en_US.rtf
	test x_$$RPM_BUILD_ROOT != x_ || chmod 644 $(BINDIST).tar.gz
	test x_$$RPM_BUILD_ROOT != x_ || chmod 755 installTed.sh
	:
	@echo Checking existence of distribution files
	test -s README
	test -s TedDocument-en_US.rtf
	test -s $(BINDIST).tar.gz
	test -x installTed.sh
	:
	rm -rf scratch
	@date >> package
	@echo Distribution is complete

########################################################################
#
#	Package containing a dynamically linked executable
#
########################################################################

package.shared:	../Ted/Ted		\
		TedBindist.tar		\
		$(BINDIST).lsm		\
		installTed.sh		\
		README
	:
	@CHECK_ID_CMD@
	:
	rm -rf scratch
	:
	mkdir scratch
	mkdir scratch/bin
	mkdir scratch/Ted
	mkdir scratch/Ted/varia
	:
	$(CHOWN_CMD) scratch
	$(CHOWN_CMD) scratch/bin
	$(CHOWN_CMD) scratch/Ted
	$(CHOWN_CMD) scratch/Ted/varia
	:
	chmod 755 scratch
	chmod 755 scratch/bin
	chmod 755 scratch/Ted
	chmod 755 scratch/Ted/varia
	:
	( cd scratch && umask 0 && tar xvf ../TedBindist.tar )
	cp scratch/Ted/TedDocument-en_US.rtf TedDocument-en_US.rtf
	:
	cp ../Ted/Ted scratch/bin/Ted
	$(CHOWN_CMD) scratch/bin/Ted
	chmod 755 scratch/bin/Ted
	:
	cp $(BINDIST).lsm scratch/Ted/varia/Ted-$(VERSION).lsm
	$(CHOWN_CMD) scratch/Ted/varia/Ted-$(VERSION).lsm
	chmod 644 scratch/Ted/varia/Ted-$(VERSION).lsm
	:
	( cd scratch && tar cvf - @TAR_CHOWN_ARGS@ * | gzip -9 > ../$(BINDIST).tar.gz )
	:
	$(CHOWN_CMD) README
	$(CHOWN_CMD) TedDocument-en_US.rtf
	$(CHOWN_CMD) $(BINDIST).tar.gz
	$(CHOWN_CMD) installTed.sh
	:
	test x_$$RPM_BUILD_ROOT != x_ || chmod 644 README
	test x_$$RPM_BUILD_ROOT != x_ || chmod 644 TedDocument-en_US.rtf
	test x_$$RPM_BUILD_ROOT != x_ || chmod 644 $(BINDIST).tar.gz
	test x_$$RPM_BUILD_ROOT != x_ || chmod 755 installTed.sh
	:
	@echo Checking existence of distribution files
	test -s README
	test -s TedDocument-en_US.rtf
	test -s $(BINDIST).tar.gz
	test -x installTed.sh
	:
	rm -rf scratch
	@date > package.shared
	@echo Distribution is complete

########################################################################
#
#	Systen V (Solaris) type pkgadd package.
#
########################################################################

sysvpkg:	../Ted/Ted.static	\
		TedBindist.tar		\
		Ted.pkginfo		\
		Ted.prototype		\
		pkg.sh			\
		README
	./pkg.sh

########################################################################
#
#	Debian style package to be used with dpkg and/or apt-get.
#
########################################################################

deb:		../Ted/Ted.static	\
		TedBindist.tar		\
		debian-control		\
		deb.sh			\
		README
	./deb.sh

########################################################################
#
#	BSD package to be used with pkg_add etc
#	(Experimental)
#
########################################################################

bsdpkg:		../Ted/Ted.static	\
		TedBindist.tar		\
		bsd-pkglist		\
		bsdpkg.sh		\
		README
	./bsdpkg.sh

########################################################################
#
#	Various files used in the package
#
########################################################################

$(BINDIST).lsm: TedBindist.lsm.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:ted-2.22-linux-amd64:$(BINDIST):g"		\
		TedBindist.lsm.in				> $@

installTed.sh: installTed.sh.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:ted-2.22-linux-amd64:$(BINDIST):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		-e "s!@CHOWN_ARG@!$(CHOWN_ARG)!g"	\
		installTed.sh.in				> $@
	chmod 755 $@ || ( rm $@ && false )

README: README.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:ted-2.22-linux-amd64:$(BINDIST):g"		\
		README.in					> $@

pkg.sh: pkg.sh.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		pkg.sh.in					> $@
	chmod 755 $@ || ( rm $@ && false )

bsdpkg.sh: bsdpkg.sh.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		bsdpkg.sh.in					> $@
	chmod 755 $@ || ( rm $@ && false )

Ted.pkginfo: Ted.pkginfo.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		Ted.pkginfo.in					> $@

Ted.prototype: Ted.prototype.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		-e "s:@PKG_OWNER@:$(PKG_OWNER):g"	\
		-e "s:@PKG_GROUP@:$(PKG_GROUP):g"	\
		Ted.prototype.in				> $@

deb.sh: deb.sh.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		deb.sh.in					> $@
	chmod 755 $@ || ( rm $@ && false )

debian-control: debian-control.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		debian-control.in				> $@

bsd-pkglist: bsd-pkglist.in
	sed	-e "s:@SYSTEM@:$(SYSTEM):g"		\
		-e "s:@MACHINE@:$(MACHINE):g"		\
		-e "s:@ARCH@:$(ARCH):g"			\
		-e "s:@PLATFORM@:$(PLATFORM):g"		\
		-e "s:@I_PREFIX@:$(I_PREFIX):g"		\
		bsd-pkglist.in					> $@

