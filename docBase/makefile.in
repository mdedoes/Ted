CC=@CC@

WFLAGS=	-Wall			\
	-Wextra			\
	-Winit-self		\
	-pedantic		\
	-Wpointer-arith		\
	-Wno-format-y2k		\
	-Wstrict-prototypes	\
	-Wmissing-declarations	\
	-Wmissing-prototypes	\
	-Wnested-externs	\
	-Wuninitialized		\
	-Wundef			\
	-Wwrite-strings		\
	-Wold-style-definition	\
	-Wno-missing-field-initializers	\
	-Wredundant-decls	\
	-Wno-unused-parameter	\
	-fsanitize=address	\
	-Wno-sign-compare	\
	-Werror

INCLUDES=			\
	-I../drawMeta		\
	-I../bitmap		\
	-I../utilPs		\
	-I../docFont		\
	-I../textEncoding	\
	-I../appUtil		\
	-I../include

CFLAGS=	\
	@CFLAGS@		\
	$(INCLUDES)

#CFLAGS= -g -O2 $(WFLAGS) $(INCLUDES)

# 81!!obs
OBS	=	\
		docTreeType.o\
		docTocField.o\
		docTextParticule.o\
		docTextLine.o\
		docTcField.o\
		docTabStopList.o\
		docTabStop.o\
		docSymbolField.o\
		docStyleSheet.o\
		docStyle.o\
		docStatistics.o\
		docShapeProperties.o\
		docShapePath.o\
		docShapeGeometry.o\
		docShapeDrawing.o\
		docSeqField.o\
		docSelectionScope.o\
		docSectProperties.o\
		docRowPropertyAdmin.o\
		docRowProperties.o\
		docRefField.o\
		docReadWmfObject.o\
		docReadFileObject.o\
		docReadEpsObject.o\
		docReadEmfObject.o\
		docReadBitmapObject.o\
		docPropertiesAdmin.o\
		docPictureProperties.o\
		docParaTabsAdmin.o\
		docParaPropertyAdmin.o\
		docParaProperties.o\
		docPagerefField.o\
